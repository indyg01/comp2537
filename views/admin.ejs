<%- include('templates/header') %>

<h1 class="mb-4">Admin Panel</h1>

<table class="table table-bordered table-striped">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>User Type</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.user_type %></td>
        <td>
          <form method="POST" action="/promote/<%= user.email %>" class="d-inline">
            <button type="submit" class="btn btn-success btn-sm">Promote to Admin</button>
          </form>
          <form method="POST" action="/demote/<%= user.email %>" class="d-inline ms-2">
            <button type="submit" class="btn btn-warning btn-sm">Demote to User</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<a href="/" class="btn btn-link mt-3">Back to Home</a>

<%- include('templates/footer') %>